{
  "name": "analityka-krop-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit && wrangler deploy --dry-run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply anal --local",
    "db:migrate": "wrangler d1 migrations apply anal --remote",
    "db:seed": "wrangler d1 execute anal --remote --file=./seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.99.0"
  }
}
